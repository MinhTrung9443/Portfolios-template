# Copy to .env in repo root (Portfolios/) — BE loads it via spring.config.import in application.properties.
# Chạy BE từ thư mục Portfolios-Templates-BE: mvn spring-boot:run

# --- Backend core ---
SERVER_PORT=8080
# MongoDB online (Atlas): Database → Connect → Drivers → copy URI, thay <password>
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/portfolios_template?retryWrites=true&w=majority
MONGODB_DATABASE=portfolios_template
# Hoặc một dòng Upstash TCP (ưu tiên hơn REDIS_HOST khi set): REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_SSL=false

# --- JWT ---
JWT_SECRET=ChangeMeToAtLeast32CharactersForHS256SigningKey
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Cookie/CORS ---
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax
AUTH_COOKIE_REFRESH_PATH=/api/auth/refresh
AUTH_COOKIE_REFRESH_MAX_AGE_SECONDS=604800

# --- OTP ---
OTP_EXPIRATION_MS=300000

# --- Gmail SMTP (cổng 587 STARTTLS) ---
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=

# --- AWS S3 (optional) ---
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
